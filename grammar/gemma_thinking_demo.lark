%llguidance {}

start: thinking output

// For thinking, Gemma uses the control sequence `<|channel>thought\n<channel|>`.
// to properly match it, you must specify it like so, as that allows it to properly
// match the block lazily.
thinking: "<|channel>thought\n" thinking_block
thinking_block[suffix="<channel|>"]: /(.|\n)*/

output: ("rubber baby buggy bumpers" " "){3}

